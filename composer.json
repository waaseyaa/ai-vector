{
    "name": "waaseyaa/ai-vector",
    "description": "Vector embedding storage and similarity search for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../queue"
        },
        {
            "type": "path",
            "url": "../api"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../workflows"
        },
        {
            "type": "path",
            "url": "../foundation"
        }
    ],
    "require": {
        "php": ">=8.5",
        "waaseyaa/entity": "^0.1.0-alpha.262",
        "waaseyaa/entity-storage": "^0.1.0-alpha.262",
        "waaseyaa/queue": "^0.1.0-alpha.262",
        "waaseyaa/api": "^0.1.0-alpha.262",
        "waaseyaa/access": "^0.1.0-alpha.262",
        "waaseyaa/workflows": "^0.1.0-alpha.262",
        "waaseyaa/foundation": "^0.1.0-alpha.262"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\AI\\Vector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\AI\\Vector\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\AI\\Vector\\AiVectorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
